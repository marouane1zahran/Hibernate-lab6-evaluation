<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/gestion_stock?serverTimezone=UTC</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password"></property>

        <property name="hibernate.connection.pool_size">10</property>

        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <property name="hibernate.show_sql">flase</property>
        <property name="hibernate.format_sql">false</property>

        <property name="hibernate.hbm2ddl.auto">create</property>

        <mapping class="ma.projet.classes.Categorie" />
        <mapping class="ma.projet.classes.Produit" />
        <mapping class="ma.projet.classes.Commande" />
        <mapping class="ma.projet.classes.LigneCommandeProduit" />
    </session-factory>
</hibernate-configuration>